# Базовый URL Creatio (только из корпоративной сети)
CREATIO_BASE_URL=https://creatio.corp.mango.ru

# Старт e2e: форма логина NUI (hash — для клиентского роутера после загрузки aspx)
CREATIO_START_URL=https://creatio.corp.mango.ru/Login/NuiLogin.aspx?ReturnUrl=%2f0%2fNui%2fViewModule.aspx#SectionModuleV2/CaseSection/

# После входа — открытие основного NUI (шаги 03–04)
CREATIO_APP_URL=/0/Nui/ViewModule.aspx#SectionModuleV2/CaseSection/

# Путь для HTTP-«пинга» в UI (без #hash; должен отвечать 2xx–4xx)
CREATIO_HTTP_PROBE_LOGIN_PATH=/Login/NuiLogin.aspx?ReturnUrl=%2f0%2fNui%2fViewModule.aspx

# Ожидание прогрузки логина NUI (мс; по умолчанию уже укорочены)
# CREATIO_NETWORK_IDLE_MS=15000
# CREATIO_LOGIN_SETTLE_MS=1000
# CREATIO_LOGIN_FIELD_TIMEOUT_MS=90000
# CREATIO_LOGIN_STABLE_MS=400

# Учётная запись для шага авторизации (только в локальном .env, не коммитьте)
CREATIO_USER=
CREATIO_PASSWORD=

# Кнопка «Войти» (если не подходит цепочка по умолчанию)
# CREATIO_LOGIN_BTN_SEL=[data-item-marker="btnLogin"]

# По умолчанию headless = встроенный Chromium Playwright. Окно Windows — только так:
# PLAYWRIGHT_HEADED=1
PLAYWRIGHT_HEADED=

# Системный Chrome вместо bundled Chromium: PW_CHANNEL=chrome (лучше отрисовка NUI)
# PW_CHANNEL=chrome

# --- Шаг 03: WebAdmin → ЛК → Помощь → Поддержка (by.mgo.su) ---
# WEBADMIN_BASE_URL=https://webadmin.by.mgo.su
# Полный URL входа (если не задан — WEBADMIN_BASE_URL + /wa/#p=sswa-module-softplatform-cdrs)
# WEBADMIN_ENTRY_URL=
WEBADMIN_USER=
WEBADMIN_PASSWORD=

# Порт локального UI/API
PORT=5174
VITE_API_URL=http://127.0.0.1:5174
